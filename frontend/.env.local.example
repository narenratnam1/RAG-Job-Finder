# Frontend Environment Variables (Next.js)
#
# QUICKEST LOCAL SETUP (no Google):
#   cd frontend && ./setup-local-env.sh && npm run dev
#
# Or copy this file to .env.local and set at minimum:
#   NEXTAUTH_SECRET=   (openssl rand -base64 32)
#   NEXTAUTH_URL=http://localhost:3000
#   NEXT_PUBLIC_SKIP_AUTH=true

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Google OAuth — only if you want real sign-in (see Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# NextAuth — required even when using SKIP_AUTH (Next.js session layer)
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Skip Google login on localhost only (never in production)
# NEXT_PUBLIC_SKIP_AUTH=true

# Example production values:
# NEXT_PUBLIC_API_URL=https://your-backend-app.up.railway.app
# NEXTAUTH_URL=https://your-frontend.vercel.app
